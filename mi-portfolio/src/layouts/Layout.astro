---
import Header from "../components/Header.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/Logo3.png" />
		<link rel="icon" href="/Logo3.png" />
		<link
			href="https://db.onlinewebfonts.com/c/a67d98abe8980caaa1768b6e27b323c6?family=Typewriter"
			rel="stylesheet"
			type="text/css"
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Gloria+Hallelujah&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Rock+Salt&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>Mi Portfolio</title>
	</head>
	<body class="overflow-x-hidden">
		<Header />
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100vh;
		background: #0a0a0f;
	}
</style>

<script>
	document.addEventListener("mousemove", (e) => {
		document.body.style.background = `radial-gradient(300px circle at ${e.clientX}px ${e.clientY}px, rgba(120,80,255,0.12), #0a0a0f 60%)`;
	});

	document.addEventListener("mouseleave", () => {
		document.body.style.background = "#0a0a0f";
	});
</script>
